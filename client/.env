# ==========================================
# 1. 식별자 및 메타데이터 (Identity)
# ==========================================
# 에이전트 이름 (Service Map에서 노드 이름으로 사용)
OTEL_LOG_AGENT_NAME=metric-log-agent

# 배포 환경 (prod, stage, dev)
DEPLOYMENT_ENV=prod

# 시스템/앱 버전 (릴리즈 트래킹용)
SYSTEM_VERSION=v1.2.0

# ==========================================
# 2. 연결 및 경로 설정 (Connection & Paths)
# ==========================================
# 중앙 수집기 주소 (프로토콜 미포함, OTel Config에서 http:// 붙임)
# 예: host.docker.internal:4317 또는 192.168.x.x:4317
OTEL_COLLECTOR_HOST=127.0.0.1:4317

# [필수] 로그가 저장되는 호스트의 실제 경로
APP_LOG_DIR=/aitrics-vc/v2_1_1-h2/logs

# ==========================================
# 3. 호환성 및 튜닝 (Compatibility & Tuning)
# ==========================================
# Docker API 버전 (호스트의 Docker 버전에 맞춰 조정, 에러 방지용)
# 구형 서버: "1.24" ~ "1.40" / 신형 서버: "1.44" 이상
DOCKER_API_VERSION="1.44"

# 메트릭 수집 주기 (기본 10s, 부하가 크면 60s로 조절)
COLLECTION_INTERVAL=10s

# 에이전트 메모리 제한 (MB 단위)
# 저사양 엣지: 200 / 일반: 400 / 고사양: 1024
MEMORY_LIMIT_MIB=400

#otel-agent-config.yaml이 들어갈 주소
CONFIG_DIR=/home/ghkwon/metric_reasoner_deploy/client/otel

NODE_ID=demo